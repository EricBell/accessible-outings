# Database Configuration
# Omit or comment out to use SQLite instead (apps/myapp/accessible_outings.db)
# DATABASE_URL=postgresql://accessible_user:your_password@localhost:5432/accessible_outings

# API Keys
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
EVENTBRITE_API_KEY=your_eventbrite_api_key_here

# Flask Configuration
SECRET_KEY=your_very_secret_key_here
FLASK_ENV=development
FLASK_DEBUG=True

# Development Settings
BYPASS_AUTH=True
DEFAULT_USER_ID=1

# Application Settings
APP_NAME=Accessible Outings Finder
DEFAULT_SEARCH_RADIUS_MILES=30
MAX_SEARCH_RADIUS_MILES=60
CACHE_TIMEOUT_HOURS=24

# Geocoding defaults (used when a ZIP code can't be resolved)
DEFAULT_LATITUDE=43.2081
DEFAULT_LONGITUDE=-71.5376

# Security settings
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Default Event Type Checkboxes
DEFAULT_EVENT_TYPE_FUN=True
DEFAULT_EVENT_TYPE_INTERESTING=True
DEFAULT_EVENT_TYPE_OFF_BEAT=True
